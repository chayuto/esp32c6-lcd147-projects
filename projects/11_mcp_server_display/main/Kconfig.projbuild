menu "MCP Canvas Configuration"

    config CANVAS_WIFI_SSID
        string "WiFi SSID"
        default "YOUR_SSID_HERE"
        help
            SSID of the Wi-Fi network to connect to.

    config CANVAS_WIFI_PASSWORD
        string "WiFi Password"
        default "YOUR_PASSWORD_HERE"
        help
            Password for the Wi-Fi network.

endmenu
